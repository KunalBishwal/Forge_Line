# Forgeline frontend configuration
# Base URL of the NestJS REST API
VITE_API_URL=http://localhost:3000
# Socket.io server (defaults to VITE_API_URL when omitted)
VITE_SOCKET_URL=http://localhost:3000
# Force demo/mock mode. Leave unset to auto-enable when no backend is reachable.
# true = always mock, false = always use the real API
VITE_USE_MOCKS=
